{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "${HORIZON_MODEL}",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 2,
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "rss": [
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/news/rss.xml",
        "enabled": true,
        "category": "ai-lab"
      },
      {
        "name": "Latent Space",
        "url": "https://www.latent.space/feed",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "Google DeepMind Podcast",
        "url": "https://feeds.simplecast.com/JT6pbPkg",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "No Priors",
        "url": "https://feeds.megaphone.fm/nopriors",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "Unsupervised Learning (Redpoint)",
        "url": "https://feeds.simplecast.com/dOSE_bdP",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "Training Data (Sequoia)",
        "url": "https://feeds.megaphone.fm/trainingdata",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "a16z AI Podcast",
        "url": "https://feeds.simplecast.com/Hb_IuXOo",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "The AI Daily Brief",
        "url": "https://anchor.fm/s/f7cac464/podcast/rss",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "Lightcone Podcast (YC)",
        "url": "https://anchor.fm/s/f58d3330/podcast/rss",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "Minus One (South Park Commons)",
        "url": "https://anchor.fm/s/f91eac68/podcast/rss",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "The Logan Bartlett Show",
        "url": "https://feeds.simplecast.com/soHIfHVn",
        "enabled": true,
        "category": "interview"
      },
      {
        "name": "Lex Fridman Podcast",
        "url": "https://lexfridman.com/feed/podcast/",
        "enabled": true,
        "category": "interview"
      },
      {
        "name": "Dwarkesh Podcast",
        "url": "https://www.dwarkesh.com/feed",
        "enabled": true,
        "category": "interview"
      },
      {
        "name": "Lenny's Podcast",
        "url": "https://www.lennysnewsletter.com/feed",
        "enabled": true,
        "category": "product"
      },
      {
        "name": "Peter Yang (Behind the Craft)",
        "url": "https://creatoreconomy.so/feed",
        "enabled": true,
        "category": "product"
      },
      {
        "name": "AI and I (Every)",
        "url": "https://every.to/podcast/feed.xml",
        "enabled": true,
        "category": "ai-podcast"
      },
      {
        "name": "One Useful Thing (Ethan Mollick)",
        "url": "https://www.oneusefulthing.org/feed",
        "enabled": true,
        "category": "newsletter"
      },
      {
        "name": "Every - Chain of Thought (Dan Shipper)",
        "url": "https://every.to/chain-of-thought/feed.xml",
        "enabled": true,
        "category": "newsletter"
      },
      {
        "name": "Every - Superorganizers",
        "url": "https://every.to/superorganizers/feed.xml",
        "enabled": true,
        "category": "newsletter"
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 150
    },
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 100
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        }
      ],
      "users": [],
      "fetch_comments": 0
    },
    "twitter": {
      "enabled": false
    },
    "github": [],
    "openbb": {
      "enabled": false
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All",
        "Python",
        "TypeScript",
        "Rust"
      ],
      "keywords": [
        "ai",
        "llm",
        "agent",
        "ml"
      ],
      "min_stars": 50,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 48,
    "max_items": null,
    "category_groups": {}
  },
  "webhook": {
    "enabled": false
  },
  "email": {
    "enabled": false,
    "smtp_server": "",
    "smtp_port": 465,
    "imap_server": "",
    "imap_port": 993,
    "email_address": ""
  }
}